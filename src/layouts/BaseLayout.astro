---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Ecology, Society, Democracy' } = Astro.props;
const pageTitle = title === 'Ecology, Society, Democracy'
  ? title
  : `${title} | Ecology, Society, Democracy`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="navbar bg-base-100 shadow-sm">
      <div class="navbar-start">
        <a href="/" class="btn btn-ghost text-xl">Ecology, Society, Democracy</a>
      </div>
      <div class="navbar-end">
        <a href="/" class="btn btn-ghost">Home</a>
        <a href="/about" class="btn btn-ghost">About</a>
        <a href="/quotes" class="btn btn-ghost">Quotes</a>
        <a href="https://twitter.com/BradVenner" class="btn btn-ghost btn-sm" target="_blank" rel="noopener">Twitter</a>
        <a href="https://github.com/bvenner" class="btn btn-ghost btn-sm" target="_blank" rel="noopener">GitHub</a>
      </div>
    </div>

    <main class="container mx-auto px-4 py-8 max-w-4xl">
      <slot />
    </main>

    <footer class="footer footer-center p-4 bg-base-200 text-base-content">
      <p>Copyright 2016-2025, Brad Venner</p>
    </footer>
  </body>
</html>
