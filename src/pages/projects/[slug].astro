---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const statusColor = {
  concept: 'badge-ghost',
  MVP: 'badge-info',
  incubating: 'badge-warning',
  graduated: 'badge-success',
}[project.data.status] ?? 'badge-ghost';
---

<BaseLayout title={project.data.title}>
  <div class="max-w-2xl">
    <div class="border-l-4 border-primary pl-6 mb-8">
      <h1 class="text-4xl font-bold mb-2">{project.data.title}</h1>
      <p class="text-xl text-base-content/70">{project.data.tagline}</p>
    </div>

    <div class="flex gap-2 mb-10">
      <span class={`badge ${statusColor}`}>{project.data.status}</span>
      <span class="badge badge-outline">{project.data.target}</span>
    </div>

    <div class="prose prose-lg max-w-none">
      <Content />
    </div>

    <div class="mt-12 pt-6 border-t border-base-300">
      <a href="/" class="text-sm text-base-content/50 hover:text-primary transition-colors">
        ← All projects
      </a>
    </div>
  </div>
</BaseLayout>
