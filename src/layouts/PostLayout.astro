---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  author: string;
}

const { title, date, author } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title}>
  <article class="max-w-3xl">
    <header class="mb-10 pb-6 border-b-4 border-blue border-l-8 border-red pl-6">
      <h1
        class="text-6xl md:text-7xl font-black leading-none mb-6 cramped"
        style="font-family: 'Playfair Display', Georgia, serif;"
      >
        {title}
      </h1>
      <p class="text-xs font-serif font-bold uppercase tracking-widest">
        {formattedDate} <span class="text-red">●</span> {author}
      </p>
    </header>
    <div class="prose prose-lg max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
