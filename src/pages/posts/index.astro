---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await getCollection('posts');
const posts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const byYear = new Map<number, typeof posts>();
for (const post of posts) {
  const year = post.data.date.getFullYear();
  if (!byYear.has(year)) byYear.set(year, []);
  byYear.get(year)!.push(post);
}
const years = [...byYear.keys()].sort((a, b) => b - a);
---

<BaseLayout title="The Notebook">
  <div class="max-w-3xl">
    <div class="mb-12">
      <h1
        class="text-6xl md:text-7xl font-black mb-4 cramped"
        style="font-family: 'Playfair Display', Georgia, serif;"
      >
        The Notebook
      </h1>
      <p class="text-sm leading-tight">
        Essays, notes, and working thoughts on technology, democracy, and economic organization.
        The research behind the projects.
      </p>
    </div>

    {years.map((year) => (
      <section class="mb-10">
        <h2
          class="text-4xl font-black text-red mb-6 pb-3 border-b-4 border-blue border-l-8 border-red pl-4 cramped"
          style="font-family: 'Playfair Display', Georgia, serif;"
        >
          {year}
        </h2>
        <ul class="space-y-2">
          {byYear.get(year)!.map((post) => {
            const d = post.data.date;
            const month = d.toLocaleDateString('en-US', { month: 'short' });
            const day = String(d.getDate()).padStart(2, '0');
            return (
              <li class="flex gap-3 items-baseline group">
                <span class="text-xs text-red font-serif font-bold uppercase shrink-0">
                  {month}.{day}
                </span>
                <a
                  href={`/posts/${post.id}`}
                  class="text-white/90 hover:text-red hover:bg-red hover:text-black transition-colors leading-tight text-sm border-b-2 border-transparent hover:border-red"
                >
                  {post.data.title}
                </a>
              </li>
            );
          })}
        </ul>
      </section>
    ))}
  </div>
</BaseLayout>
