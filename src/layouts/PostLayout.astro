---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  author: string;
}

const { title, date, author } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title}>
  <article class="max-w-3xl">
    <header class="mb-12 pb-8 border-b-4 border-blue">
      <h1
        class="text-5xl font-black leading-tight mb-6"
        style="font-family: 'Playfair Display', Georgia, serif;"
      >
        {title}
      </h1>
      <p class="text-sm font-serif font-bold uppercase tracking-widest">
        {formattedDate} &mdash; {author}
      </p>
    </header>
    <div class="prose prose-lg max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
