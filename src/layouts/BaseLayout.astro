---
import '../styles/global.css';

interface Props {
  title?: string;
}

const SITE_TITLE = 'mycor.io';
const { title = SITE_TITLE } = Astro.props;
const pageTitle = title === SITE_TITLE ? title : `${title} | ${SITE_TITLE}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body style="font-family: 'Inter', system-ui, sans-serif;">
    <!-- Header: Punk aesthetic with thick red bottom border -->
    <header class="border-b-4 border-red">
      <div class="container mx-auto px-4 max-w-5xl">
        <div class="flex items-center justify-between py-6">
          <a
            href="/"
            class="text-3xl font-black transition-colors text-red"
            style="font-family: 'Playfair Display', Georgia, serif; letter-spacing: 0.05em;"
          >
            mycor.io
          </a>
          <nav class="flex items-center gap-8">
            <a
              href="/"
              class="font-serif text-sm font-bold uppercase transition-colors hover:text-red"
            >
              Home
            </a>
            <a
              href="/posts"
              class="font-serif text-sm font-bold uppercase transition-colors hover:text-red"
            >
              Notebook
            </a>
            <a
              href="/about"
              class="font-serif text-sm font-bold uppercase transition-colors hover:text-red"
            >
              About
            </a>
          </nav>
        </div>
      </div>
    </header>

    <main class="container mx-auto px-4 py-10 max-w-5xl">
      <slot />
    </main>

    <!-- Footer: Punk aesthetic with thick blue top border -->
    <footer class="border-t-4 border-blue mt-16">
      <div class="container mx-auto px-4 max-w-5xl py-6 text-sm" style="font-family: 'Playfair Display', Georgia, serif;">
        mycor.io — open source software for cooperatives and nonprofits
      </div>
    </footer>
  </body>
</html>
