---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const statusColor = {
  concept: 'border-blue text-blue',
  MVP: 'border-red bg-red text-black',
  incubating: 'border-blue text-blue',
  graduated: 'border-red text-red',
}[project.data.status] ?? 'border-blue text-blue';
---

<BaseLayout title={project.data.title}>
  <div class="max-w-3xl">
    <!-- Title section with thick borders and shadow -->
    <div class="border-l-8 border-red border-t-4 border-blue pl-8 pt-6 mb-10 shadow-red">
      <h1
        class="text-7xl font-black mb-4 leading-none cramped"
        style="font-family: 'Playfair Display', Georgia, serif;"
      >
        {project.data.title}
      </h1>
      <p class="text-sm font-bold text-white/85">{project.data.tagline}</p>
    </div>

    <!-- Status and target badges -->
    <div class="flex gap-4 mb-12 flex-wrap">
      <span
        class={`text-xs font-serif font-bold uppercase border-2 px-3 py-2 ${statusColor}`}
      >
        {project.data.status}
      </span>
      <span class="text-xs font-serif font-bold uppercase border-2 border-blue text-blue px-3 py-2">
        {project.data.target}
      </span>
    </div>

    <!-- Content -->
    <div class="prose prose-lg max-w-none">
      <Content />
    </div>

    <!-- Back link -->
    <div class="mt-16 pt-8 border-t-4 border-blue">
      <a
        href="/"
        class="font-serif font-bold text-red hover:bg-red hover:text-black px-2 py-1 transition-colors"
      >
        ← All projects
      </a>
    </div>
  </div>
</BaseLayout>
