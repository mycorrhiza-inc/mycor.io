---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => a.data.order - b.data.order);

const statusColors: Record<string, string> = {
  concept: 'border-blue text-blue',
  MVP: 'border-red bg-red text-black',
  incubating: 'border-blue text-blue',
  graduated: 'border-red text-red',
};
---

<BaseLayout>
  <!-- Hero: Asymmetric layout with large serif H1 -->
  <section class="mb-20 pt-10">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-start">
      <!-- Left: Large serif heading -->
      <div class="md:col-span-2">
        <h1
          class="text-6xl md:text-7xl font-black leading-tight mb-6"
          style="font-family: 'Playfair Display', Georgia, serif; letter-spacing: -0.02em;"
        >
          Open source<br />
          software for the<br />
          <span class="text-red">cooperative</span> &<br />
          <span class="text-blue">nonprofit</span> sector
        </h1>
      </div>

      <!-- Right: Callout box with red border -->
      <div class="border-4 border-red p-6 md:col-span-1">
        <div class="text-sm space-y-4 leading-relaxed">
          <p>
            Cooperatives and nonprofits solving humanity's biggest problems with corporate software.
          </p>
          <p>
            We're building the infrastructure they actually need.
          </p>
        </div>
      </div>
    </div>

    <!-- Main description -->
    <div class="mt-12 max-w-3xl">
      <p class="text-lg leading-relaxed">
        mycor.io runs the full product lifecycle — research, design, specification, engineering —
        as a volunteer organization. Every project combines the technical and social work
        together, because you can't separate them and succeed at either.
      </p>
    </div>
  </section>

  <!-- Projects: Asymmetric grid with punk styling -->
  <section class="mb-20">
    <h2 class="text-xs font-serif font-bold tracking-widest uppercase mb-8 border-b-4 border-blue pb-4">
      Projects
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {projects.map((project, index) => (
        <a
          href={`/projects/${project.id}`}
          class={`group block border-4 p-6 transition-all hover:shadow-red ${
            index % 3 === 0 ? 'md:col-span-2 border-red' : 'border-blue'
          }`}
        >
          <div class="flex items-start justify-between gap-4 mb-4">
            <h3
              class="text-2xl font-bold group-hover:text-red transition-colors"
              style="font-family: 'Playfair Display', Georgia, serif;"
            >
              {project.data.title}
            </h3>
            <span
              class={`text-xs font-serif font-bold uppercase shrink-0 border-2 px-2 py-1 ${
                statusColors[project.data.status] ?? 'border-blue text-blue'
              }`}
            >
              {project.data.status}
            </span>
          </div>
          <p class="text-white/75 text-sm leading-relaxed mb-4">
            {project.data.tagline}
          </p>
          <span class="text-xs uppercase font-serif font-bold text-blue">{project.data.target}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- The Notebook: Blue top border section -->
  <section class="max-w-3xl border-t-4 border-blue pt-12">
    <h2 class="text-xs font-serif font-bold tracking-widest uppercase mb-6">
      The Notebook
    </h2>
    <div class="space-y-4 leading-relaxed">
      <p>
        Essays, notes, and working thoughts on technology, democracy, and economic organization.
      </p>
      <p>
        The research behind the projects. Written over the last decade as we've tried to understand
        what it would take to make this work.
      </p>
    </div>
    <a
      href="/posts"
      class="inline-block mt-6 font-serif font-bold text-red hover:bg-red hover:text-black px-2 py-1 border-b-2 border-red transition-colors"
    >
      Browse the archive →
    </a>
  </section>
</BaseLayout>
