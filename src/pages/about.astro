---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About">
  <div class="max-w-3xl">
    <h1
      class="text-6xl md:text-7xl font-black mb-8 cramped"
      style="font-family: 'Playfair Display', Georgia, serif;"
    >
      About
    </h1>
    <div class="prose prose-lg max-w-none border-l-8 border-blue border-t-4 border-red pl-8 pt-6">
      <p>
        <span class="text-blue font-bold">Ecology, Society, Democracy</span> is the notebook of Brad Venner and is a
        chronicle of my readings and musings on democratic ecosocialism.
      </p>
      <p class="italic text-white/75">
        Beware — I'm not a trained philosopher, and the notebook contains little but
        partial and incomplete notes.
      </p>
    </div>
  </div>
</BaseLayout>
