---
import '../styles/global.css';

interface Props {
  title?: string;
}

const SITE_TITLE = 'mycor.io';
const { title = SITE_TITLE } = Astro.props;
const pageTitle = title === SITE_TITLE ? title : `${title} | ${SITE_TITLE}`;
---

<!doctype html>
<html lang="en" data-theme="wthwmt">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body style="font-family: 'Inter', system-ui, sans-serif;">
    <header class="border-b border-base-300">
      <div class="container mx-auto px-4 max-w-5xl">
        <div class="flex items-center justify-between py-4">
          <a
            href="/"
            class="text-lg font-bold tracking-tight hover:text-primary transition-colors"
            style="font-family: 'Playfair Display', Georgia, serif;"
          >
            mycor.io
          </a>
          <nav class="flex items-center gap-1">
            <a href="/" class="btn btn-ghost btn-sm">Home</a>
            <a href="/posts" class="btn btn-ghost btn-sm">Notebook</a>
            <a href="/about" class="btn btn-ghost btn-sm">About</a>
          </nav>
        </div>
      </div>
    </header>

    <main class="container mx-auto px-4 py-10 max-w-5xl">
      <slot />
    </main>

    <footer class="border-t border-base-300 mt-16">
      <div class="container mx-auto px-4 max-w-5xl py-6 text-sm text-base-content/40">
        mycor.io — open source software for cooperatives and nonprofits
      </div>
    </footer>
  </body>
</html>
