---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About">
  <div class="max-w-3xl">
    <h1
      class="text-5xl font-black mb-8"
      style="font-family: 'Playfair Display', Georgia, serif;"
    >
      About
    </h1>
    <div class="prose prose-lg max-w-none border-l-6 border-blue pl-8">
      <p>
        Ecology, Society, Democracy is the notebook of Brad Venner and is a
        chronicle of my readings and musings on democratic ecosocialism. Beware,
        I'm not a trained philosopher, and the notebook contains little but
        partial and incomplete notes.
      </p>
    </div>
  </div>
</BaseLayout>
