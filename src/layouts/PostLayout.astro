---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  author: string;
}

const { title, date, author } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title}>
  <article>
    <header class="mb-10 pb-8 border-b border-base-300">
      <h1 class="text-4xl font-bold leading-tight mb-4">{title}</h1>
      <p class="text-base-content/50 text-sm tracking-wide uppercase">
        {formattedDate} &mdash; {author}
      </p>
    </header>
    <div class="prose prose-lg max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
